{
  "name": "orthos-code",
  "version": "1.0.0",
  "description": "AI coding assistant for the terminal, powered by Ollama",
  "type": "module",
  "bin": {
    "orthos": "./dist/bin/orthos.js",
    "orthos2": "./bin/orthos2-runner.js"
  },
  "main": "./dist/src/app.js",
  "scripts": {
    "dev": "tsx bin/orthos.ts",
    "build": "tsup",
    "start": "node dist/bin/orthos.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.4.1",
    "cli-highlight": "^2.1.11",
    "conf": "^13.1.0",
    "gpt-tokenizer": "^2.8.1",
    "grammy": "^1.40.0",
    "ink": "^5.2.1",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
    "meow": "^13.0.0",
    "react": "^18.3.1",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
